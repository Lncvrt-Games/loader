{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "fs:default",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-exists",
    "os:default",
    "opener:default",
    "dialog:default"
  ]
}